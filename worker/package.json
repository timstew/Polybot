{
  "name": "polybot-copy-listener",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create polybot",
    "db:init": "wrangler d1 execute polybot --file=schema.sql",
    "db:init:remote": "wrangler d1 execute polybot --file=schema.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
